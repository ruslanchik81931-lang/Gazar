<Window x:Class="Gazar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gazar" Height="450" Width="800"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Background="#D3D3D3">
            <Button Content="Open" Width="75" Margin="5" />
            <Button Content="Save" Width="75" Margin="5" />
            <Button Content="Exit" Width="75" Margin="5" />
        </ToolBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <ListBox Grid.Column="0" Margin="5" Background="#FFFFFF" />
            <TextBox Grid.Column="1" Margin="5" Background="#F9F9F9" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
        </Grid>

        <StatusBar Grid.Row="2" Background="#D3D3D3">
            <TextBlock Text="Ready" VerticalAlignment="Center" Margin="5" />
        </StatusBar>
    </Grid>
</Window>